{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api/$1" },
    { "source": "/spots/(.*)", "destination": "/backend/spots/$1" },
    { "source": "/spots", "destination": "/backend/spots" },
    { "source": "/ask", "destination": "/backend/ask" },
    { "source": "/forecast", "destination": "/backend/forecast" },
    { "source": "/routes", "destination": "/backend/routes" },
    { "source": "/rainfall/(.*)", "destination": "/backend/rainfall/$1" },
    { "source": "/sensors/(.*)", "destination": "/backend/sensors/$1" },
    { "source": "/sensors", "destination": "/backend/sensors" },
    { "source": "/static/(.*)", "destination": "/backend/static/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
