{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main:app"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/spots/(.*)", "destination": { "service": "backend" } },
    { "source": "/spots", "destination": { "service": "backend" } },
    { "source": "/ask", "destination": { "service": "backend" } },
    { "source": "/forecast", "destination": { "service": "backend" } },
    { "source": "/routes", "destination": { "service": "backend" } },
    { "source": "/rainfall/(.*)", "destination": { "service": "backend" } },
    { "source": "/sensors/(.*)", "destination": { "service": "backend" } },
    { "source": "/sensors", "destination": { "service": "backend" } },
    { "source": "/static/(.*)", "destination": { "service": "backend" } },
    { "source": "/((?!api|spots|ask|forecast|routes|rainfall|sensors|static|assets|[^/]+\\.[^/]+$).*)", "destination": { "service": "frontend", "path": "/index.html" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
