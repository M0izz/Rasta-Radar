{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/([^/]+\\.[^/]+)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
