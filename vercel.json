{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/spots/(.*)", "dest": "backend/main.py" },
    { "src": "/spots", "dest": "backend/main.py" },
    { "src": "/ask", "dest": "backend/main.py" },
    { "src": "/forecast", "dest": "backend/main.py" },
    { "src": "/routes", "dest": "backend/main.py" },
    { "src": "/rainfall/(.*)", "dest": "backend/main.py" },
    { "src": "/sensors/(.*)", "dest": "backend/main.py" },
    { "src": "/sensors", "dest": "backend/main.py" },
    { "src": "/static/(.*)", "dest": "backend/main.py" },
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/([^/]+\\.[^/]+)", "dest": "frontend/dist/$1" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
