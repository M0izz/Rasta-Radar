{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend", "path": "/api/$1" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
